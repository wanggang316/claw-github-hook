# Global secrets (set via `wrangler secret put`)
GITHUB_WEBHOOK_SECRET=your-webhook-secret-here
AUTO_REVIEW=false

# Per-route token secrets
# Names must match the openclawToken values in KV routes config (without the $ prefix)
TOKEN_PROJ1=your-openclaw-token-for-project-1-here
TOKEN_PROJ2=your-openclaw-token-for-project-2-here

# Sample KV routes config (upload to ROUTES_KV namespace under key "routes"):
# [
#   {
#     "repo": "acme/backend",
#     "openclawUrl": "https://openclaw.example.com",
#     "openclawToken": "$TOKEN_PROJ1",
#     "agentId": "backend-builder",
#     "ghAccount": "acme-bot",
#     "botMention": "@acme-bot"
#   },
#   {
#     "repo": "acme/frontend",
#     "openclawUrl": "https://openclaw.example.com",
#     "openclawToken": "$TOKEN_PROJ2",
#     "agentId": "frontend-builder",
#     "autoReview": true,
#     "ghAccount": "acme-bot",
#     "botMention": "@acme-bot"
#   },
#   {
#     "repo": "*",
#     "openclawUrl": "https://openclaw.example.com",
#     "openclawToken": "$TOKEN_PROJ1",
#     "agentId": "product-builder"
#   }
# ]
#
# Optional fields per route:
#   ghAccount   — GitHub username for `gh auth switch --user <account>` (multi-account support)
#   botMention  — Custom trigger mention (default: "@claw"), e.g. "@mybot"
#   autoReview  — Override global AUTO_REVIEW for this repo
