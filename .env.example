# GitHub App webhook secret (set via `wrangler secret put`)
# Must match the Webhook secret configured in your GitHub App settings.
GITHUB_WEBHOOK_SECRET=your-github-app-webhook-secret-here

# Global default for PR auto-review when a route does not set autoReview.
AUTO_REVIEW=false

# OpenClaw hook tokens
# Names must match the openclawToken values in KV routes config (without the $ prefix).
TOKEN_ORG_A=your-openclaw-token-for-org-a-here
TOKEN_ORG_B=your-openclaw-token-for-org-b-here

# Sample KV routes config (upload to ROUTES_KV namespace under key "routes")
# One record per GitHub App installation / organization.
# [
#   {
#     "installationId": 12345678,
#     "owner": "acme",
#     "defaults": {
#       "openclawUrl": "https://openclaw.acme.example.com",
#       "openclawToken": "$TOKEN_ORG_A",
#       "agentId": "<default_agent_id>",
#       "autoReview": true,
#       "ghAccount": "acme-bot",
#       "botMention": "@acme-bot"
#     },
#     "repos": {
#       "backend": {
#         "agentId": "<backend_agent_id>"
#       },
#       "frontend": {
#         "agentId": "<frontend_agent_id>",
#         "autoReview": false
#       }
#     }
#   },
#   {
#     "installationId": 87654321,
#     "owner": "beta-org",
#     "defaults": {
#       "openclawUrl": "https://openclaw.beta.example.com",
#       "openclawToken": "$TOKEN_ORG_B",
#       "agentId": "<beta_default_agent_id>",
#       "ghAccount": "beta-bot"
#     },
#     "repos": {
#       "mobile": {
#         "agentId": "<mobile_agent_id>"
#       }
#     }
#   }
# ]
#
# Route resolution priority:
#   1. installationId exact match
#   2. owner fallback match
#   3. defaults merged with repos[repoName]
#
# Required fields per org route:
#   installationId  — Recommended. GitHub App installation ID for this org
#   owner           — GitHub organization login
#   defaults        — Default OpenClaw target for this org
#
# Optional fields inside defaults or repos.<repoName>:
#   ghAccount   — GitHub username for `gh auth switch --user <account>`
#   botMention  — Custom trigger mention (default: "@claw" or "@ghAccount")
#   autoReview  — Override global AUTO_REVIEW for this org or repo
